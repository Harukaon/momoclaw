    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
